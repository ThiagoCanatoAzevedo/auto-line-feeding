# -- APP CONFIGS --
APP_NAME="Auth Microservice"
APP_URL=http://localhost:8003
FILES_DRIVER=local

# -- MYSQL CONFIGS --
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=
MYSQL_PSWD=
MYSQL_DATABASE=auth
TEST_MYSQL_URL=mysql+mysqlconnector://root:password@localhost:${MYSQL_PORT}/test_auth

# -- JWT CONFIGS --
SECRET_KEY="SECRET_KEY"
ALGORITHM="HS256"
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=1